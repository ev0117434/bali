# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CHANNEL=ch:spread_signals

# Trading defaults (can be overridden at startup prompt)
POSITION_SIZE_USDT=100
SPREAD_REDUCTION=0.30
ORDER_POLL_INTERVAL=1.0
PNL_POLL_INTERVAL=2.0
SIGNAL_MAX_AGE_SEC=30
ORDER_TIMEOUT_MIN=5
LOG_DIR=logs

# --- Binance ---
BINANCE_API_KEY=
BINANCE_SECRET=
# BINANCE_TESTNET=false   # set to "true" to use testnet

# --- Bybit ---
BYBIT_API_KEY=
BYBIT_SECRET=
# BYBIT_TESTNET=false

# --- OKX ---
OKX_API_KEY=
OKX_SECRET=
OKX_PASSPHRASE=          # passphrase created when you made the API key

# --- Gate.io ---
GATE_API_KEY=
GATE_SECRET=
