# Redis
REDIS_URL=redis://localhost:6379/0

# Key TTL: must be > STALE_THRESHOLD_SEC to avoid blind spots in stale_monitor
# Default 300 (not 120 as in TZ v2.1 — see implementation plan for reasoning)
REDIS_KEY_TTL=300

# WebSocket
WS_PING_INTERVAL=30         # Binance=30, Bybit=20 (overridden per-script)
WS_RECV_TIMEOUT=60          # Seconds before reconnect if no data received
RECONNECT_MAX_DELAY=60      # Max backoff delay in seconds
SYMBOLS_PER_CONN=150        # Symbols per WebSocket connection (exchange limit is 200)

# Logging
LOG_LEVEL=INFO              # DEBUG / INFO / WARNING / ERROR / CRITICAL

# stale_monitor
STALE_THRESHOLD_SEC=60      # Age in seconds before symbol is considered stale
SCAN_INTERVAL_SEC=30        # How often stale_monitor scans Redis
SCAN_COUNT=500              # SCAN batch size (balance between speed and Redis load)

# latency_monitor
SAMPLING_INTERVAL_SEC=10    # How often latency_monitor reports
SAMPLING_MAX_KEYS=200       # Max keys per SCAN step (rolling cursor, not full scan)
ANOMALY_WARN_MS=1000        # End-to-end latency threshold for WARNING
ANOMALY_CRIT_MS=5000        # End-to-end latency threshold for CRITICAL
