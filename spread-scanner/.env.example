# Spread Scanner — переменные окружения
# Скопируйте в .env и настройте под своё окружение

# Redis
REDIS_URL=redis://localhost:6379/0

# Минимальный спред для генерации сигнала (в процентах)
# Сигнал отправляется если spread_pct >= MIN_SPREAD_PCT
MIN_SPREAD_PCT=1.0

# Интервал между циклами сканирования (в миллисекундах)
SCAN_INTERVAL_MS=100

# Данные считаются устаревшими если старше N секунд
STALE_THRESHOLD_SEC=5

# TTL ключа сигнала в Redis (в секундах)
SIGNAL_TTL=60

# Cooldown: повторный сигнал по тому же (direction, symbol) не раньше чем через N секунд
SIGNAL_COOLDOWN_SEC=3600

# Prometheus (0 = отключено, 1 = включено; требует prometheus-client)
ENABLE_PROMETHEUS=0
PROMETHEUS_PORT=9091

# Логирование
LOG_LEVEL=INFO
